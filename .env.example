# Authentication: PAT (default) or OAUTH
AUTH_METHOD=PAT

# REST API host (optional)
GITHUB_API_BASE_URL=https://api.github.com

# --- Personal Access Token (required when AUTH_METHOD=PAT) ---
GITHUB_TOKEN=ghp_your_personal_access_token_here

# --- GitHub OAuth App (required when AUTH_METHOD=OAUTH) ---
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=http://localhost:8000/auth/callback

# Register the same redirect URI in GitHub → Settings → Developer settings → OAuth Apps.
